# .env.example — API key configuration reference (no env vars required for normal use)
#
# For unattended automation (e.g., launchd daily_ingest.sh):
# Store your Anthropic API key at ~/.config/anthropic/key (mode 0600).
# The script System_Config/daily_ingest.sh will automatically read it as ANTHROPIC_API_KEY.
#
# For interactive use (GUI session), the Claude Code login keychain is used instead.
#
# Example setup:
#   mkdir -p ~/.config/anthropic
#   echo "sk-..." > ~/.config/anthropic/key
#   chmod 0600 ~/.config/anthropic/key
