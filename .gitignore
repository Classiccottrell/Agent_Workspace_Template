# ── OS / editor cruft ────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.code-workspace
.idea/
.vscode/

# ── Dependencies / build output ──────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
dist/
build/
.next/
out/
.nuxt/
.output/
.cache/
.turbo/
.parcel-cache/

# ── Logs / temp ──────────────────────────────────────────────────────────
*.log
*.tmp

# ── System_Config runtime artifacts ──────────────────────────────────────
# Keep the logs/ directory (via .gitkeep) but ship none of its contents.
System_Config/logs/*
!System_Config/logs/.gitkeep
# System_Config/ health-check output is generated at runtime, never committed.
# (The microsite copy under docs/ — status.js + health.html — IS committed so the
#  published GitHub Pages site can show the last-known health snapshot. See healthcheck.sh.)
System_Config/status.json
System_Config/status_page.html
# Rendered launchd plists live in ~/Library/LaunchAgents, but ignore any
# accidentally-generated copies in the tree.
*.plist
!System_Config/*.plist.tmpl

# ── Vault_Brain runtime / Obsidian internals ─────────────────────────────
Vault_Brain/sources/.ingested.log
.obsidian/
**/.obsidian/
**/.obsidian/workspace*.json

# ── Claude Code local state ──────────────────────────────────────────────
.claude/settings.local.json
.claude/worktrees/

# ── MCP config (user-specific; the .example is tracked) ──────────────────
.mcp.json
!.mcp.json.example

# ── Secrets / credentials (never commit) ─────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.cert

# ── Nested git repos (independent clones, not submodules) ────────────────
Projects/impeccable/
Projects/tweakcn/
Projects/classiccottrell.github.io/
Projects/AI-Mineral-system/
Projects/Agent_Workspace_Template/
Projects/ClassicCottrell_design-system/
Projects/UX_Skill_Repo_1.0/
Projects/ascii-art/
Projects/Brutal-UX/app/

# ── Tool cache / stray worktrees ───────────────────────────────────────
**/.impeccable/

.claude/skills/how-i-write/
.agents/skills/how-i-write/
